# ── Odoo connection ────────────────────────────────────────────────────────
ODOO_URL=https://yourcompany.odoo.com
ODOO_DB=yourcompany
ODOO_ADMIN_USERNAME=admin@yourcompany.com
# Generate an API key in Odoo: Settings → Technical → API Keys
ODOO_ADMIN_API_KEY=your_odoo_api_key_here

# ── OAuth 2.0 ──────────────────────────────────────────────────────────────
# Public URL of this server (used in OAuth metadata)
SERVER_URL=https://mcp-odoo.up.railway.app

# Credentials your web app uses to obtain tokens
OAUTH_CLIENT_ID=your-web-app-client-id
OAUTH_CLIENT_SECRET=change-me-use-a-long-random-string

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-generate-with-python-secrets

# Token lifetime in minutes (default 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Server ─────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
